{% extends 'base.html.twig' %}

{% block title %}Product: {{ product.name }}{% endblock %}

{% block page_title %}Products{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .product-view-container {
            max-width: 1200px;
            margin: 2rem auto;
        }

        .product-view-card {
            background: #ffffff;
            border-radius: 16px;
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
            overflow: hidden;
        }

        .product-view-content {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 2rem;
            padding: 2rem;
        }

        .product-view-image {
            width: 100%;
            height: 400px;
            border-radius: 12px;
            overflow: hidden;
            position: relative;
        }

        .product-view-image-placeholder {
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, #f5f5f5 0%, #e0e0e0 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #999;
            font-size: 3rem;
        }

        .product-view-image-placeholder::before {
            content: '📦';
            font-size: 4rem;
            opacity: 0.3;
        }

        .product-view-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .product-view-details {
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
        }

        .product-view-name {
            font-size: 2rem;
            font-weight: 700;
            color: #2b2b2b;
            margin: 0;
        }

        .product-view-info {
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .product-view-info-item {
            display: flex;
            flex-direction: column;
            gap: 0.25rem;
        }

        .product-view-info-label {
            font-size: 0.85rem;
            font-weight: 600;
            color: #6c757d;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .product-view-info-value {
            font-size: 1.1rem;
            color: #2b2b2b;
            font-weight: 500;
        }

        .product-view-price {
            font-size: 1.75rem;
            font-weight: 700;
            color: #8f5644;
        }

        .product-view-description {
            padding: 1rem;
            background: #f8f9fa;
            border-radius: 8px;
            color: #2b2b2b;
            line-height: 1.6;
            white-space: pre-wrap;
        }

        .product-view-actions {
            display: flex;
            gap: 1rem;
            padding: 2rem;
            border-top: 1px solid #eee;
            flex-wrap: wrap;
        }

        .product-view-btn {
            padding: 0.75rem 1.5rem;
            border-radius: 8px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            border: none;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
        }

        .product-view-btn-edit {
            background: #2b2b2b;
            color: white;
        }

        .product-view-btn-edit:hover {
            background: #1a1a1a;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(43, 43, 43, 0.3);
        }

        .product-view-btn-delete {
            background: #dc3545;
            color: white;
        }

        .product-view-btn-delete:hover {
            background: #c82333;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(220, 53, 69, 0.3);
        }

        .product-view-btn-back {
            background: #6c757d;
            color: white;
        }

        .product-view-btn-back:hover {
            background: #5a6268;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(108, 117, 125, 0.3);
        }

        @media (max-width: 768px) {
            .product-view-content {
                grid-template-columns: 1fr;
                padding: 1.5rem;
            }

            .product-view-image {
                height: 300px;
            }

            .product-view-name {
                font-size: 1.5rem;
            }

            .product-view-actions {
                flex-direction: column;
            }

            .product-view-btn {
                width: 100%;
                justify-content: center;
            }
        }
    </style>
{% endblock %}

{% block content %}
<div class="product-view-container">
    <div class="product-view-card">
        <div class="product-view-content">
            <div class="product-view-image">
                {% if product.image %}
                    <img src="{{ asset('uploads/products/' ~ product.image) }}" alt="{{ product.name }}">
                {% else %}
                    <div class="product-view-image-placeholder">
                        <!-- Placeholder icon -->
                    </div>
                {% endif %}
            </div>

            <div class="product-view-details">
                <h1 class="product-view-name">{{ product.name }}</h1>

                <div class="product-view-info">
                    <div class="product-view-info-item">
                        <span class="product-view-info-label">Category</span>
                        <span class="product-view-info-value">{{ product.category ?: 'Uncategorized' }}</span>
                    </div>

                    <div class="product-view-info-item">
                        <span class="product-view-info-label">Price</span>
                        <span class="product-view-info-value product-view-price">₱{{ product.price }}</span>
                    </div>

                    <div class="product-view-info-item">
                        <span class="product-view-info-label">Stock</span>
                        <span class="product-view-info-value">{{ product.stock }}</span>
                    </div>

                    {% if product.description %}
                    <div class="product-view-info-item">
                        <span class="product-view-info-label">Description</span>
                        <div class="product-view-description">{{ product.description }}</div>
                    </div>
                    {% endif %}
                </div>
            </div>
        </div>

        <div class="product-view-actions">
            {% if is_granted('ROLE_ADMIN') or (app.user and product.createdBy and product.createdBy.id == app.user.id) %}
                <a href="{{ path('app_product_edit', { id: product.id }) }}" class="product-view-btn product-view-btn-edit">
                    <i class="bi bi-pencil"></i>
                    Edit
                </a>
                <form action="{{ path('app_product_delete', {'id': product.id}) }}" method="POST" style="display: inline; margin: 0;" onsubmit="return confirm('Are you sure you want to delete this product?');">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ product.id) }}">
                    <button type="submit" class="product-view-btn product-view-btn-delete">
                        <i class="bi bi-trash"></i>
                        Delete
                    </button>
                </form>
            {% endif %}
            <a href="{{ path('app_product_index') }}" class="product-view-btn product-view-btn-back">
                <i class="bi bi-arrow-left"></i>
                Back to list
            </a>
        </div>
    </div>
</div>
{% endblock %}
