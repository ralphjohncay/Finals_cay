{% extends 'base.html.twig' %}

{% block title %}Analytics & Reports - Admin{% endblock %}

{% block page_title %}Analytics & Reports{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .analytics-container {
            max-width: 1400px;
            margin: 0 auto;
        }

        .analytics-header {
            margin-bottom: 2rem;
        }

        .analytics-header h1 {
            font-size: 2rem;
            font-weight: 700;
            color: #2b2b2b;
            margin: 0 0 0.5rem 0;
        }

        .analytics-header p {
            color: #6c757d;
            margin: 0;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 1.5rem;
            margin-bottom: 2rem;
        }

        .stat-card {
            background: #ffffff;
            border-radius: 16px;
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
            padding: 2rem;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

        .stat-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 6px 20px rgba(0, 0, 0, 0.15);
        }

        .stat-card-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 1rem;
        }

        .stat-card-title {
            font-size: 0.9rem;
            font-weight: 600;
            color: #6c757d;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin: 0;
        }

        .stat-card-icon {
            font-size: 2rem;
            opacity: 0.8;
        }

        .stat-card-value {
            font-size: 2.5rem;
            font-weight: 700;
            color: #2b2b2b;
            margin: 0;
        }

        .stat-card-primary .stat-card-icon {
            color: #8f5644;
        }

        .stat-card-primary .stat-card-value {
            color: #8f5644;
        }

        .stat-card-success .stat-card-icon {
            color: #28a745;
        }

        .stat-card-success .stat-card-value {
            color: #28a745;
        }

        .stat-card-warning .stat-card-icon {
            color: #ffc107;
        }

        .stat-card-warning .stat-card-value {
            color: #ffc107;
        }

        .stat-card-info .stat-card-icon {
            color: #17a2b8;
        }

        .stat-card-info .stat-card-value {
            color: #17a2b8;
        }

        .stat-card-danger .stat-card-icon {
            color: #dc3545;
        }

        .stat-card-danger .stat-card-value {
            color: #dc3545;
        }

        .stat-card-subtitle {
            font-size: 0.85rem;
            color: #6c757d;
            margin-top: 0.5rem;
        }

        .revenue-section {
            background: #ffffff;
            border-radius: 16px;
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
            padding: 2rem;
            margin-bottom: 2rem;
        }

        .revenue-section-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 1.5rem;
            padding-bottom: 1rem;
            border-bottom: 2px solid #f0f0f0;
        }

        .revenue-section-title {
            font-size: 1.5rem;
            font-weight: 600;
            color: #2b2b2b;
            margin: 0;
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .revenue-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 1.5rem;
        }

        .revenue-card {
            background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
            border-radius: 12px;
            padding: 1.5rem;
            border-left: 4px solid #8f5644;
        }

        .revenue-card-label {
            font-size: 0.85rem;
            font-weight: 600;
            color: #6c757d;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 0.5rem;
        }

        .revenue-card-value {
            font-size: 1.75rem;
            font-weight: 700;
            color: #2b2b2b;
        }

        .growth-indicator {
            display: inline-flex;
            align-items: center;
            gap: 0.25rem;
            font-size: 0.85rem;
            font-weight: 600;
            margin-top: 0.5rem;
            padding: 0.25rem 0.5rem;
            border-radius: 4px;
        }

        .growth-positive {
            background: #d4edda;
            color: #155724;
        }

        .growth-negative {
            background: #f8d7da;
            color: #721c24;
        }

        .growth-neutral {
            background: #e2e3e5;
            color: #383d41;
        }

        .orders-section {
            background: #ffffff;
            border-radius: 16px;
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
            padding: 2rem;
        }

        .orders-section-header {
            margin-bottom: 1.5rem;
            padding-bottom: 1rem;
            border-bottom: 2px solid #f0f0f0;
        }

        .orders-section-title {
            font-size: 1.5rem;
            font-weight: 600;
            color: #2b2b2b;
            margin: 0;
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .orders-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 1.5rem;
        }

        @media (max-width: 768px) {
            .stats-grid {
                grid-template-columns: 1fr;
            }

            .revenue-grid {
                grid-template-columns: 1fr;
            }

            .orders-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
{% endblock %}

{% block content %}
<div class="analytics-container">
    <div class="analytics-header">
        <h1>Financial Analytics</h1>
        <p>Track your revenue, earnings, and business performance</p>
    </div>

    <div class="stats-grid">
        <div class="stat-card stat-card-primary">
            <div class="stat-card-header">
                <h3 class="stat-card-title">Total Revenue</h3>
                <i class="bi bi-cash-coin stat-card-icon"></i>
            </div>
            <p class="stat-card-value">₱{{ total_revenue|number_format(2, '.', ',') }}</p>
            <p class="stat-card-subtitle">All completed orders</p>
        </div>

        <div class="stat-card stat-card-success">
            <div class="stat-card-header">
                <h3 class="stat-card-title">This Month</h3>
                <i class="bi bi-calendar-month stat-card-icon"></i>
            </div>
            <p class="stat-card-value">₱{{ this_month_revenue|number_format(2, '.', ',') }}</p>
            <p class="stat-card-subtitle">
                {% if revenue_growth > 0 %}
                    <span class="growth-indicator growth-positive">
                        <i class="bi bi-arrow-up"></i> {{ revenue_growth|number_format(1) }}% vs last month
                    </span>
                {% elseif revenue_growth < 0 %}
                    <span class="growth-indicator growth-negative">
                        <i class="bi bi-arrow-down"></i> {{ revenue_growth|number_format(1) }}% vs last month
                    </span>
                {% else %}
                    <span class="growth-indicator growth-neutral">No change</span>
                {% endif %}
            </p>
        </div>

        <div class="stat-card stat-card-info">
            <div class="stat-card-header">
                <h3 class="stat-card-title">This Week</h3>
                <i class="bi bi-calendar-week stat-card-icon"></i>
            </div>
            <p class="stat-card-value">₱{{ this_week_revenue|number_format(2, '.', ',') }}</p>
            <p class="stat-card-subtitle">Last 7 days</p>
        </div>

        <div class="stat-card stat-card-warning">
            <div class="stat-card-header">
                <h3 class="stat-card-title">Today</h3>
                <i class="bi bi-calendar-day stat-card-icon"></i>
            </div>
            <p class="stat-card-value">₱{{ today_revenue|number_format(2, '.', ',') }}</p>
            <p class="stat-card-subtitle">Today's earnings</p>
        </div>

        <div class="stat-card stat-card-danger">
            <div class="stat-card-header">
                <h3 class="stat-card-title">Pending Revenue</h3>
                <i class="bi bi-hourglass-split stat-card-icon"></i>
            </div>
            <p class="stat-card-value">₱{{ pending_revenue|number_format(2, '.', ',') }}</p>
            <p class="stat-card-subtitle">{{ pending_orders + pending_approval_orders }} pending orders ({{ pending_approval_orders }} awaiting approval)</p>
        </div>

        <div class="stat-card stat-card-primary">
            <div class="stat-card-header">
                <h3 class="stat-card-title">Average Order Value</h3>
                <i class="bi bi-graph-up stat-card-icon"></i>
            </div>
            <p class="stat-card-value">₱{{ average_order_value|number_format(2, '.', ',') }}</p>
            <p class="stat-card-subtitle">Per completed order</p>
        </div>
    </div>

    <div class="revenue-section">
        <div class="revenue-section-header">
            <h2 class="revenue-section-title">
                <i class="bi bi-pie-chart"></i>
                Revenue Breakdown
            </h2>
        </div>
        <div class="revenue-grid">
            <div class="revenue-card">
                <div class="revenue-card-label">Total Revenue</div>
                <div class="revenue-card-value">₱{{ total_revenue|number_format(2, '.', ',') }}</div>
            </div>
            <div class="revenue-card">
                <div class="revenue-card-label">This Month</div>
                <div class="revenue-card-value">₱{{ this_month_revenue|number_format(2, '.', ',') }}</div>
            </div>
            <div class="revenue-card">
                <div class="revenue-card-label">Last Month</div>
                <div class="revenue-card-value">₱{{ last_month_revenue|number_format(2, '.', ',') }}</div>
            </div>
            <div class="revenue-card">
                <div class="revenue-card-label">This Week</div>
                <div class="revenue-card-value">₱{{ this_week_revenue|number_format(2, '.', ',') }}</div>
            </div>
            <div class="revenue-card">
                <div class="revenue-card-label">Today</div>
                <div class="revenue-card-value">₱{{ today_revenue|number_format(2, '.', ',') }}</div>
            </div>
            <div class="revenue-card">
                <div class="revenue-card-label">Pending</div>
                <div class="revenue-card-value">₱{{ pending_revenue|number_format(2, '.', ',') }}</div>
            </div>
        </div>
    </div>

    <div class="orders-section">
        <div class="orders-section-header">
            <h2 class="orders-section-title">
                <i class="bi bi-cart-check"></i>
                Order Statistics
            </h2>
        </div>
        <div class="orders-grid">
            <div class="stat-card stat-card-info">
                <div class="stat-card-header">
                    <h3 class="stat-card-title">Total Orders</h3>
                    <i class="bi bi-cart stat-card-icon"></i>
                </div>
                <p class="stat-card-value">{{ total_orders }}</p>
                <p class="stat-card-subtitle">All time</p>
            </div>

            <div class="stat-card stat-card-success">
                <div class="stat-card-header">
                    <h3 class="stat-card-title">Completed</h3>
                    <i class="bi bi-check-circle stat-card-icon"></i>
                </div>
                <p class="stat-card-value">{{ completed_orders }}</p>
                <p class="stat-card-subtitle">Orders completed</p>
            </div>

            <div class="stat-card stat-card-warning">
                <div class="stat-card-header">
                    <h3 class="stat-card-title">Pending</h3>
                    <i class="bi bi-clock stat-card-icon"></i>
                </div>
                <p class="stat-card-value">{{ pending_orders }}</p>
                <p class="stat-card-subtitle">Awaiting completion</p>
            </div>

            <div class="stat-card stat-card-danger">
                <div class="stat-card-header">
                    <h3 class="stat-card-title">Pending Approval</h3>
                    <i class="bi bi-hourglass-split stat-card-icon"></i>
                </div>
                <p class="stat-card-value">{{ pending_approval_orders }}</p>
                <p class="stat-card-subtitle">Awaiting admin approval</p>
            </div>
        </div>
    </div>
</div>
{% endblock %}
