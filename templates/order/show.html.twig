{% extends 'base.html.twig' %}

{% block title %}Order {{ order.id }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .order-view-container {
            max-width: 1000px;
            margin: 2rem auto;
        }

        .order-view-card {
            background: #ffffff;
            border-radius: 16px;
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
            overflow: hidden;
        }

        .order-view-header {
            background: linear-gradient(138deg, #e6d2b8 0%, #b88968 32%, #7d4a3a 68%, #3d221c 100%);
            color: white;
            padding: 2rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 1rem;
        }

        .order-view-header h2 {
            margin: 0;
            font-size: 1.75rem;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .order-view-content {
            padding: 2rem;
        }

        .order-view-section {
            margin-bottom: 2rem;
        }

        .order-view-section:last-child {
            margin-bottom: 0;
        }

        .order-view-section-title {
            font-size: 1.25rem;
            font-weight: 600;
            color: #2b2b2b;
            margin-bottom: 1rem;
            padding-bottom: 0.5rem;
            border-bottom: 2px solid #f0f0f0;
        }

        .order-info-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 1.5rem;
            margin-bottom: 1.5rem;
        }

        .order-info-item {
            display: flex;
            flex-direction: column;
            gap: 0.25rem;
        }

        .order-info-label {
            font-size: 0.85rem;
            font-weight: 600;
            color: #6c757d;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .order-info-value {
            font-size: 1.1rem;
            color: #2b2b2b;
            font-weight: 500;
        }

        .order-status-badge {
            display: inline-block;
            padding: 0.4rem 0.85rem;
            border-radius: 6px;
            font-size: 0.8rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .order-status-pending-approval {
            background: #fff3cd;
            color: #856404;
        }

        .order-status-pending {
            background: #d1ecf1;
            color: #0c5460;
        }

        .order-status-approved {
            background: #cfe2ff;
            color: #084298;
        }

        .order-status-completed {
            background: #d4edda;
            color: #155724;
        }

        .order-status-canceled {
            background: #f8d7da;
            color: #721c24;
        }

        .order-items-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 1rem;
        }

        .order-items-table thead {
            background: #f8f9fa;
        }

        .order-items-table th {
            padding: 1rem;
            text-align: left;
            font-weight: 600;
            font-size: 0.9rem;
            color: #2b2b2b;
            border-bottom: 2px solid #dee2e6;
        }

        .order-items-table td {
            padding: 1rem;
            border-bottom: 1px solid #eee;
            color: #2b2b2b;
        }

        .order-items-table tbody tr:last-child td {
            border-bottom: none;
        }

        .order-total-row {
            background: #f8f9fa;
            font-weight: 700;
            font-size: 1.1rem;
        }

        .order-view-actions {
            display: flex;
            gap: 1rem;
            padding: 2rem;
            border-top: 1px solid #eee;
            flex-wrap: wrap;
        }

        .order-view-btn {
            padding: 0.75rem 1.5rem;
            border-radius: 8px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            border: none;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
        }

        .order-view-btn-back {
            background: #6c757d;
            color: white;
        }

        .order-view-btn-back:hover {
            background: #5a6268;
            transform: translateY(-2px);
        }

        .order-view-btn-edit {
            background: #667eea;
            color: white;
        }

        .order-view-btn-edit:hover {
            background: #5568d3;
            transform: translateY(-2px);
        }

        .order-view-btn-approve {
            background: #28a745;
            color: white;
        }

        .order-view-btn-approve:hover {
            background: #218838;
            transform: translateY(-2px);
        }

        .order-view-btn-reject {
            background: #dc3545;
            color: white;
        }

        .order-view-btn-reject:hover {
            background: #c82333;
            transform: translateY(-2px);
        }

        .order-view-btn-delete {
            background: #dc3545;
            color: white;
        }

        .order-view-btn-delete:hover {
            background: #c82333;
            transform: translateY(-2px);
        }

        @media (max-width: 768px) {
            .order-view-header {
                flex-direction: column;
                align-items: flex-start;
            }

            .order-info-grid {
                grid-template-columns: 1fr;
            }

            .order-view-actions {
                flex-direction: column;
            }

            .order-view-btn {
                width: 100%;
                justify-content: center;
            }
        }
    </style>
{% endblock %}

{% block content %}
<div class="order-view-container">
    <div class="order-view-card">
        <div class="order-view-header">
            <h2>
                <i class="bi bi-receipt"></i>
                Order #{{ order.id }}
            </h2>
        </div>

        <div class="order-view-content">
            <div class="order-view-section">
                <h3 class="order-view-section-title">Order Information</h3>
                <div class="order-info-grid">
                    <div class="order-info-item">
                        <span class="order-info-label">Customer</span>
                        <span class="order-info-value">{{ order.customer ? order.customer.name : 'N/A' }}</span>
                    </div>
                    <div class="order-info-item">
                        <span class="order-info-label">Order Date</span>
                        <span class="order-info-value">{{ order.orderDate ? order.orderDate|date('Y-m-d H:i:s') : 'N/A' }}</span>
                    </div>
                    <div class="order-info-item">
                        <span class="order-info-label">Status</span>
                        <span class="order-status-badge 
                            {% if order.status == 'pending_approval' %}order-status-pending-approval
                            {% elseif order.status == 'pending' %}order-status-pending
                            {% elseif order.status == 'approved' %}order-status-approved
                            {% elseif order.status == 'completed' %}order-status-completed
                            {% elseif order.status == 'canceled' %}order-status-canceled
                            {% else %}order-status-pending-approval{% endif %}">
                            {{ order.status|replace({'_': ' '})|title }}
                        </span>
                    </div>
                    <div class="order-info-item">
                        <span class="order-info-label">Total Price</span>
                        <span class="order-info-value" style="font-size: 1.5rem; font-weight: 700; color: #8f5644;">₱{{ order.totalPrice|default('0.00') }}</span>
                    </div>
                </div>
            </div>

            <div class="order-view-section">
                <h3 class="order-view-section-title">Order Items</h3>
                <table class="order-items-table">
                    <thead>
                        <tr>
                            <th>Item</th>
                            <th>Type</th>
                            <th>Price</th>
                            <th>Quantity</th>
                            <th>Subtotal</th>
            </tr>
                    </thead>
                    <tbody>
                        {% for item in order.orderItems %}
            <tr>
                                <td>{{ item.name }}</td>
                                <td><span style="text-transform: capitalize;">{{ item.type ?: 'N/A' }}</span></td>
                                <td>₱{{ item.price|default('0.00') }}</td>
                                <td>{{ item.quantity }}</td>
                                <td>₱{{ item.subtotal|number_format(2, '.', ',') }}</td>
            </tr>
                        {% else %}
            <tr>
                                <td colspan="5" style="text-align: center; padding: 2rem; color: #6c757d;">No items in this order</td>
            </tr>
                        {% endfor %}
                        <tr class="order-total-row">
                            <td colspan="4" style="text-align: right;">Total:</td>
                            <td>₱{{ order.totalPrice|default('0.00') }}</td>
            </tr>
        </tbody>
    </table>
            </div>
        </div>

        <div class="order-view-actions">
            <a href="{{ path('app_order_index') }}" class="order-view-btn order-view-btn-back">
                <i class="bi bi-arrow-left"></i>
                Back to Orders
            </a>
            {% if order.status != 'approved' and order.status != 'completed' and order.status != 'canceled' %}
                <a href="{{ path('app_order_edit', {'id': order.id}) }}" class="order-view-btn order-view-btn-edit">
                    <i class="bi bi-pencil"></i>
                    Edit Order
                </a>
            {% endif %}
            {% if is_granted('ROLE_ADMIN') and order.status == 'pending_approval' %}
                <form action="{{ path('app_order_approve', {'id': order.id}) }}" method="POST" style="display: inline; margin: 0;" onsubmit="return confirm('Are you sure you want to approve order #{{ order.id }}?');">
                    <input type="hidden" name="_token" value="{{ csrf_token('approve' ~ order.id) }}">
                    <button type="submit" class="order-view-btn order-view-btn-approve">
                        <i class="bi bi-check-circle"></i>
                        Approve Order
                    </button>
                </form>
                <form action="{{ path('app_order_reject', {'id': order.id}) }}" method="POST" style="display: inline; margin: 0;" onsubmit="return confirm('Are you sure you want to reject order #{{ order.id }}?');">
                    <input type="hidden" name="_token" value="{{ csrf_token('reject' ~ order.id) }}">
                    <button type="submit" class="order-view-btn order-view-btn-reject">
                        <i class="bi bi-x-circle"></i>
                        Reject Order
                    </button>
                </form>
            {% endif %}
            {% if is_granted('ROLE_ADMIN') %}
                <form action="{{ path('app_order_delete', {'id': order.id}) }}" method="POST" style="display: inline; margin: 0;" onsubmit="return confirm('Are you sure you want to delete order #{{ order.id }}?');">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ order.id) }}">
                    <button type="submit" class="order-view-btn order-view-btn-delete">
                        <i class="bi bi-trash"></i>
                        Delete Order
                    </button>
                </form>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
