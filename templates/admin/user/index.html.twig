{% extends 'base.html.twig' %}

{% block title %}User Management - Admin{% endblock %}

{% block page_title %}User Management{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .user-management-container {
            max-width: 1400px;
            margin: 0 auto;
        }

        .user-header-actions {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 2rem;
            flex-wrap: wrap;
            gap: 1rem;
        }

        .user-create-btn {
            padding: 0.75rem 1.5rem;
            background: linear-gradient(138deg, #e6d2b8 0%, #b88968 32%, #7d4a3a 68%, #3d221c 100%);
            color: white;
            text-decoration: none;
            border-radius: 10px;
            font-weight: 600;
            font-size: 1rem;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            transition: all 0.3s ease;
            box-shadow: 0 2px 8px rgba(105, 62, 48, 0.2);
        }

        .user-create-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(105, 62, 48, 0.3);
        }

        .user-table-card {
            background: #ffffff;
            border-radius: 16px;
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
            overflow: hidden;
        }

        .user-table {
            width: 100%;
            border-collapse: collapse;
        }

        .user-table thead {
            background: linear-gradient(138deg, #e6d2b8 0%, #b88968 32%, #7d4a3a 68%, #3d221c 100%);
            color: white;
        }

        .user-table th {
            padding: 1rem 1.25rem;
            text-align: left;
            font-weight: 600;
            font-size: 0.875rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .user-table tbody tr {
            border-bottom: 1px solid #eee;
            transition: background-color 0.2s ease;
        }

        .user-table tbody tr:hover {
            background-color: #f8f9fa;
        }

        .user-table tbody tr:last-child {
            border-bottom: none;
        }

        .user-table td {
            padding: 1rem 1.25rem;
            vertical-align: middle;
            font-size: 0.9rem;
        }

        .user-table td:nth-child(3) {
            min-width: 150px;
        }

        .user-table td:last-child {
            min-width: 300px;
            white-space: nowrap;
        }

        .user-badge {
            display: inline-block;
            padding: 0.35rem 0.7rem;
            border-radius: 6px;
            font-size: 0.8rem;
            font-weight: 600;
            margin-right: 0.4rem;
            margin-bottom: 0.2rem;
        }

        .badge-admin {
            background: #f8d7da;
            color: #721c24;
        }

        .badge-staff {
            background: #d1ecf1;
            color: #0c5460;
        }

        .badge-customer {
            background: #d4edda;
            color: #155724;
        }

        .badge-active {
            background: #d4edda;
            color: #155724;
        }

        .badge-disabled {
            background: #f8d7da;
            color: #721c24;
        }

        .user-actions {
            display: flex;
            gap: 0.4rem;
            align-items: center;
            flex-wrap: wrap;
            justify-content: flex-start;
        }

        .user-action-btn {
            padding: 0.45rem 0.7rem;
            border-radius: 6px;
            font-size: 0.8rem;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.2s ease;
            border: none;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 0.35rem;
            white-space: nowrap;
        }

        .user-action-btn i {
            font-size: 0.9rem;
        }

        .user-action-btn span {
            font-size: 0.8rem;
        }

        .user-action-btn-edit {
            background: #4a90e2;
            color: white;
        }

        .user-action-btn-edit:hover {
            background: #357abd;
            transform: translateY(-1px);
        }

        .user-action-btn-toggle {
            background: #ffc107;
            color: #333;
        }

        .user-action-btn-toggle:hover {
            background: #e0a800;
            transform: translateY(-1px);
        }

        .user-action-btn-delete {
            background: #dc3545;
            color: white;
        }

        .user-action-btn-delete:hover {
            background: #c82333;
            transform: translateY(-1px);
        }

        .user-action-btn-reset {
            background: #17a2b8;
            color: white;
        }

        .user-action-btn-reset:hover {
            background: #138496;
            transform: translateY(-1px);
        }

        .user-empty-state {
            padding: 3rem;
            text-align: center;
            color: #999;
        }

        .user-empty-state-icon {
            font-size: 3rem;
            margin-bottom: 1rem;
            opacity: 0.5;
        }

        @media (max-width: 768px) {
            .user-table {
                font-size: 0.875rem;
            }

            .user-table th,
            .user-table td {
                padding: 0.75rem 1rem;
            }

            .user-table td:last-child {
                min-width: auto;
            }

            .user-actions {
                flex-direction: column;
                align-items: stretch;
                gap: 0.3rem;
            }

            .user-action-btn {
                width: 100%;
                justify-content: center;
                padding: 0.5rem;
            }

            .user-action-btn span {
                display: inline;
            }
        }
    </style>
{% endblock %}

{% block content %}
<div class="user-management-container">
    <div class="user-header-actions">
        <h2 style="margin: 0; font-size: 1.75rem; font-weight: 700; color: #2b2b2b;">Users</h2>
        <a href="{{ path('admin_user_new') }}" class="user-create-btn">
            <i class="bi bi-plus-circle"></i> Create New User
        </a>
    </div>

    <div class="user-table-card">
        <table class="user-table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Status</th>
                    <th>Created</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for user in users %}
                    <tr>
                        <td>
                            <strong>{{ user.name }}</strong>
                        </td>
                        <td>{{ user.email }}</td>
                        <td>
                            <div style="display: flex; flex-wrap: wrap; gap: 0.3rem;">
                                {% for role in user.roles %}
                                    {% if role == 'ROLE_ADMIN' %}
                                        <span class="user-badge badge-admin">Admin</span>
                                    {% elseif role == 'ROLE_STAFF' %}
                                        <span class="user-badge badge-staff">Staff</span>
                                    {% elseif role == 'ROLE_USER' %}
                                        <span class="user-badge badge-customer">Customer</span>
                                    {% endif %}
                                {% endfor %}
                            </div>
                        </td>
                        <td>
                            <span class="user-badge {% if user.isActive %}badge-active{% else %}badge-disabled{% endif %}">
                                {{ user.isActive ? 'Active' : 'Disabled' }}
                            </span>
                        </td>
                        <td>{{ user.createdAt ? user.createdAt|date('M d, Y') : 'N/A' }}</td>
                        <td>
                            <div class="user-actions">
                                <a href="{{ path('admin_user_edit', {'id': user.id}) }}" class="user-action-btn user-action-btn-edit" title="Edit User">
                                    <i class="bi bi-pencil-square"></i>
                                    <span>Edit</span>
                                </a>
                                {% if app.user and app.user.id != user.id %}
                                    <form method="post" action="{{ path('admin_user_reset_password', {'id': user.id}) }}" style="display: inline; margin: 0;" onsubmit="return confirm('Are you sure you want to reset the password for {{ user.email }}? A temporary password will be generated.');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('reset_password' ~ user.id) }}">
                                        <button type="submit" class="user-action-btn user-action-btn-reset" title="Reset Password">
                                            <i class="bi bi-key"></i>
                                            <span>Reset</span>
                                        </button>
                                    </form>
                                    <form method="post" action="{{ path('admin_user_toggle_status', {'id': user.id}) }}" style="display: inline; margin: 0;">
                                        <input type="hidden" name="_token" value="{{ csrf_token('toggle_status' ~ user.id) }}">
                                        <button type="submit" class="user-action-btn user-action-btn-toggle" title="{{ user.isActive ? 'Disable User' : 'Enable User' }}">
                                            <i class="bi bi-{% if user.isActive %}toggle-on{% else %}toggle-off{% endif %}"></i>
                                            <span>{{ user.isActive ? 'Disable' : 'Enable' }}</span>
                                        </button>
                                    </form>
                                    <form method="post" action="{{ path('admin_user_delete', {'id': user.id}) }}" style="display: inline; margin: 0;" onsubmit="return confirm('Are you sure you want to delete this user? This action cannot be undone.');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}">
                                        <button type="submit" class="user-action-btn user-action-btn-delete" title="Delete User">
                                            <i class="bi bi-trash"></i>
                                            <span>Delete</span>
                                        </button>
                                    </form>
                                {% endif %}
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="6" class="user-empty-state">
                            <div class="user-empty-state-icon">
                                <i class="bi bi-people"></i>
                            </div>
                            <p style="margin: 0; font-size: 1.1rem;">No users found</p>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
