{% extends 'base.html.twig' %}

{% block title %}Change Password - Admin{% endblock %}

{% block page_title %}User Management{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .password-change-container {
            max-width: 700px;
            margin: 2rem auto;
        }

        .password-change-card {
            background: #ffffff;
            border-radius: 16px;
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
            overflow: hidden;
        }

        .password-change-header {
            background: linear-gradient(138deg, #e6d2b8 0%, #b88968 32%, #7d4a3a 68%, #3d221c 100%);
            padding: 2rem 2.5rem;
            color: white;
        }

        .password-change-header h2 {
            margin: 0;
            font-size: 1.75rem;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .password-change-content {
            padding: 2.5rem;
        }

        .password-change-section {
            margin-bottom: 2rem;
        }

        .password-change-section:last-child {
            margin-bottom: 0;
        }

        .password-form-group {
            margin-bottom: 2rem;
        }

        .password-form-group label {
            display: block;
            font-weight: 600;
            margin-bottom: 0.5rem;
            color: #2b2b2b;
            font-size: 0.95rem;
        }

        .password-wrapper {
            position: relative;
        }

        .password-wrapper input {
            width: 100%;
            padding: 0.75rem 1rem;
            padding-right: 45px;
            border: 1px solid #ddd;
            border-radius: 10px;
            font-size: 1rem;
            box-sizing: border-box;
            transition: all 0.3s ease;
            background-color: #fff;
        }

        .password-wrapper input:focus {
            outline: none;
            border-color: #8f5644;
            box-shadow: 0 0 0 3px rgba(105, 62, 48, 0.15);
        }

        .password-toggle-btn {
            position: absolute;
            right: 12px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            cursor: pointer;
            color: #6c757d;
            font-size: 1.1rem;
            padding: 5px;
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 10;
        }

        .password-toggle-btn:hover {
            color: #8f5644;
        }

        .password-form-error {
            color: #dc3545;
            font-size: 0.875rem;
            margin-top: 0.5rem;
        }

        .password-form-actions {
            display: flex;
            gap: 1rem;
            margin-top: 2.5rem;
            padding-top: 2rem;
            border-top: 1px solid #eee;
        }

        .password-btn {
            padding: 0.75rem 1.5rem;
            border-radius: 10px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            border: none;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
        }

        .password-btn-primary {
            background-color: #8f5644;
            color: white;
        }

        .password-btn-primary:hover {
            background-color: #3f2a24;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(105, 62, 48, 0.3);
        }

        .password-btn-secondary {
            background-color: #6c757d;
            color: white;
        }

        .password-btn-secondary:hover {
            background-color: #5a6268;
            transform: translateY(-2px);
        }

        .user-info-box {
            background: #f8f9fa;
            padding: 1rem 1.25rem;
            border-radius: 10px;
            margin-bottom: 2rem;
            border-left: 4px solid #8f5644;
        }

        .user-info-box strong {
            color: #8f5644;
        }

        @media (max-width: 768px) {
            .password-change-header {
                padding: 1.5rem;
            }
            .password-change-content {
                padding: 1.5rem;
            }
        }
    </style>
{% endblock %}

{% block content %}
<div class="password-change-container">
    <div class="password-change-card">
        <div class="password-change-header">
            <h2>
                <i class="bi bi-key"></i> Change Password
            </h2>
        </div>

        <div class="password-change-content">
            <div class="user-info-box">
                <strong>User:</strong> {{ user.name }} ({{ user.email }})
            </div>

            {% if form.vars.submitted and not form.vars.valid %}
                <div style="background: #f8d7da; color: #721c24; padding: 1rem; border-radius: 8px; margin-bottom: 1.5rem; border: 1px solid #f5c6cb;">
                    <strong>Please fix the following errors:</strong>
                    {{ form_errors(form) }}
                </div>
            {% endif %}

            {{ form_start(form, { 'attr': { 'novalidate': 'novalidate' } }) }}
                <div class="password-change-section">
                    <div class="password-form-group">
                        {{ form_label(form.newPassword.first) }}
                        <div class="password-wrapper">
                            {{ form_widget(form.newPassword.first, { 'attr': {'class': 'form-control'} }) }}
                            <button type="button" class="password-toggle-btn" aria-label="Toggle password visibility">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>
                        {% if form.newPassword.first.vars.errors|length > 0 %}
                            <div class="password-form-error">
                                {% for error in form.newPassword.first.vars.errors %}
                                    {{ error.message }}
                                {% endfor %}
                            </div>
                        {% endif %}
                    </div>

                    <div class="password-form-group">
                        {{ form_label(form.newPassword.second) }}
                        <div class="password-wrapper">
                            {{ form_widget(form.newPassword.second, { 'attr': {'class': 'form-control'} }) }}
                            <button type="button" class="password-toggle-btn" aria-label="Toggle password visibility">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>
                        {% if form.newPassword.second.vars.errors|length > 0 %}
                            <div class="password-form-error">
                                {% for error in form.newPassword.second.vars.errors %}
                                    {{ error.message }}
                                {% endfor %}
                            </div>
                        {% endif %}
                    </div>

                    <div class="password-form-actions">
                        <button type="submit" class="password-btn password-btn-primary">
                            <i class="bi bi-check-circle"></i> Update Password
                        </button>
                        <a href="{{ path('admin_user_edit', {'id': user.id}) }}" class="password-btn password-btn-secondary">
                            <i class="bi bi-x-circle"></i> Cancel
                        </a>
                    </div>
                </div>
            {{ form_end(form) }}
        </div>
    </div>
</div>

{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const toggleButtons = document.querySelectorAll('.password-toggle-btn');
            
            toggleButtons.forEach(button => {
                button.addEventListener('click', function() {
                    const wrapper = this.closest('.password-wrapper');
                    const input = wrapper.querySelector('input[type="password"], input[type="text"]');
                    
                    if (input) {
                        if (input.type === 'password') {
                            input.type = 'text';
                            this.querySelector('i').classList.remove('bi-eye');
                            this.querySelector('i').classList.add('bi-eye-slash');
                        } else {
                            input.type = 'password';
                            this.querySelector('i').classList.remove('bi-eye-slash');
                            this.querySelector('i').classList.add('bi-eye');
                        }
                    }
                });
            });
        });
    </script>
{% endblock %}
{% endblock %}

