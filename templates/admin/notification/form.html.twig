{% extends 'base.html.twig' %}

{% block title %}{{ title }}{% endblock %}
{% block page_title %}{{ title }}{% endblock %}

{% block content %}
<div class="dashboard-container" style="max-width:720px;">
    <a href="{{ path('admin_notifications_index') }}" style="color:#ff8c00;">← Back to notifications</a>
    <h1 style="margin-top:16px;">{{ title }}</h1>
    {{ form_start(form) }}
        {{ form_row(form.title) }}
        {{ form_row(form.message) }}
        {{ form_row(form.type) }}
        {{ form_row(form.audience) }}
        {{ form_row(form.priority) }}
        {{ form_row(form.startsAt) }}
        {{ form_row(form.expiresAt) }}
        {{ form_row(form.isActive) }}
        <button type="submit" style="margin-top:16px;padding:10px 20px;background:#ff8c00;color:#fff;border:none;border-radius:8px;font-weight:600;cursor:pointer;">Save</button>
    {{ form_end(form) }}
</div>
{% endblock %}
