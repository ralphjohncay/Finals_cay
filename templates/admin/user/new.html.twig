{% extends 'base.html.twig' %}

{% block title %}Create User - Admin{% endblock %}

{% block page_title %}Create New User{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .user-form-container {
            max-width: 900px;
            margin: 2rem auto;
        }

        .user-form-card {
            background: #ffffff;
            border-radius: 16px;
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
            overflow: hidden;
        }

        .user-form-header {
            background: linear-gradient(138deg, #e6d2b8 0%, #b88968 32%, #7d4a3a 68%, #3d221c 100%);
            padding: 2rem 2.5rem;
            color: white;
        }

        .user-form-header h2 {
            margin: 0;
            font-size: 1.75rem;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .user-form-content {
            padding: 2.5rem;
        }

        @media (max-width: 768px) {
            .user-form-header {
                padding: 1.5rem;
            }
            .user-form-content {
                padding: 1.5rem;
            }
        }

        .user-form-container form {
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
        }

        .user-form-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 2rem;
        }

        @media (max-width: 768px) {
            .user-form-grid {
                grid-template-columns: 1fr;
                gap: 1.5rem;
            }
        }

        .user-form-container .form-group {
            margin-bottom: 1.5rem;
        }

        .user-form-container label {
            display: block;
            font-weight: 600;
            margin-bottom: 0.5rem;
            color: #2b2b2b;
            font-size: 0.95rem;
        }

        .user-form-container input[type="text"],
        .user-form-container input[type="email"],
        .user-form-container input[type="password"] {
            width: 100%;
            padding: 0.75rem 1rem;
            border: 1px solid #ddd;
            border-radius: 10px;
            font-size: 1rem;
            box-sizing: border-box;
            transition: all 0.3s ease;
            background-color: #fff;
        }

        .user-form-container input:focus {
            outline: none;
            border-color: #8f5644;
            box-shadow: 0 0 0 3px rgba(105, 62, 48, 0.15);
        }

        .user-form-container .form-help {
            font-size: 0.875rem;
            color: #6c757d;
            margin-top: 0.5rem;
            line-height: 1.4;
        }

        /* Role checkboxes styling */
        .user-form-container .roles-container {
            display: flex;
            flex-direction: column;
            gap: 1rem;
            padding: 1rem;
            background: #f8f9fa;
            border-radius: 10px;
            border: 1px solid #e9ecef;
        }

        .user-form-container .form-check {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.5rem;
        }

        .user-form-container .form-check input[type="checkbox"] {
            width: 18px;
            height: 18px;
            cursor: pointer;
            accent-color: #8f5644;
        }

        .user-form-container .form-check label {
            margin: 0;
            font-weight: 500;
            cursor: pointer;
            flex: 1;
        }

        /* Active checkbox styling */
        .user-form-container .checkbox-container {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 1rem;
            background: #f8f9fa;
            border-radius: 10px;
            border: 1px solid #e9ecef;
        }

        .user-form-container .checkbox-container input[type="checkbox"] {
            width: 18px;
            height: 18px;
            cursor: pointer;
            accent-color: #8f5644;
        }

        .user-form-container .checkbox-container label {
            margin: 0;
            font-weight: 500;
            cursor: pointer;
        }

        /* Error messages */
        .user-form-container .form-error {
            color: #dc3545;
            font-size: 0.875rem;
            margin-top: 0.5rem;
        }

        .user-form-container .alert-danger {
            background: #f8d7da;
            color: #721c24;
            padding: 1rem;
            border-radius: 8px;
            margin-bottom: 1.5rem;
            border: 1px solid #f5c6cb;
        }

        /* Form actions */
        .user-form-actions {
            display: flex;
            justify-content: flex-end;
            gap: 1rem;
            margin-top: 1.5rem;
            padding-top: 1.5rem;
            border-top: 1px solid #eee;
        }

        .user-form-actions .btn {
            padding: 0.75rem 1.5rem;
            border-radius: 10px;
            font-weight: 600;
            font-size: 0.95rem;
            transition: all 0.3s ease;
            cursor: pointer;
            border: none;
            text-decoration: none;
            display: inline-block;
        }

        .user-form-actions .btn-primary {
            background-color: #8f5644;
            color: #fff;
        }

        .user-form-actions .btn-primary:hover {
            background-color: #3f2a24;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(94, 64, 57, 0.3);
        }

        .user-form-actions .btn-secondary {
            background-color: #6c757d;
            color: #fff;
        }

        .user-form-actions .btn-secondary:hover {
            background-color: #5a6268;
            transform: translateY(-2px);
        }
    </style>
{% endblock %}

{% block content %}
<div class="user-form-container">
    <div class="user-form-card">
        <div class="user-form-header">
            <h2>
                <i class="bi bi-person-plus"></i> Create New User
            </h2>
        </div>

        <div class="user-form-content">

        {% if form.vars.submitted and not form.vars.valid %}
            <div class="alert alert-danger">
                <strong>Please fix the following errors:</strong>
                <ul style="margin: 0.5rem 0 0 0; padding-left: 1.5rem;">
                    {% for error in form.vars.errors %}
                        <li>{{ error.message }}</li>
                    {% endfor %}
                </ul>
            </div>
        {% endif %}

        {{ form_start(form, { attr: { id: 'user_form', class: 'user-form' } }) }}
            <div class="user-form-grid">
                <div>
                    <div class="form-group">
                        {{ form_label(form.name) }}
                        {{ form_widget(form.name, { 'attr': {'class': 'form-control'} }) }}
                        {% if form.name.vars.errors|length > 0 %}
                            <div class="form-error">
                                {% for error in form.name.vars.errors %}
                                    {{ error.message }}
                                {% endfor %}
                            </div>
                        {% endif %}
                    </div>

                    <div class="form-group">
                        {{ form_label(form.email) }}
                        {{ form_widget(form.email, { 'attr': {'class': 'form-control'} }) }}
                        {% if form.email.vars.errors|length > 0 %}
                            <div class="form-error">
                                {% for error in form.email.vars.errors %}
                                    {{ error.message }}
                                {% endfor %}
                            </div>
                        {% endif %}
                    </div>

                    <div class="form-group">
                        {{ form_label(form.plainPassword) }}
                        <div class="password-wrapper">
                            {{ form_widget(form.plainPassword, { 'attr': {'class': 'form-control'} }) }}
                            <button type="button" class="password-toggle-btn" aria-label="Toggle password visibility">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>
                        {% if form.plainPassword.vars.errors|length > 0 %}
                            <div class="form-error">
                                {% for error in form.plainPassword.vars.errors %}
                                    {{ error.message }}
                                {% endfor %}
                            </div>
                        {% endif %}
                    </div>
                </div>

                <div>
                    <div class="form-group">
                        <label style="margin-bottom: 0.75rem;">{{ form.roles.vars.label }}</label>
                        <div class="roles-container">
                            {% for child in form.roles %}
                                <div class="form-check">
                                    {{ form_widget(child, { 'attr': {'class': 'form-check-input'} }) }}
                                    {{ form_label(child, null, { 'label_attr': {'class': 'form-check-label'} }) }}
                                </div>
                            {% endfor %}
                        </div>
                        {% if form.roles.vars.errors|length > 0 %}
                            <div class="form-error">
                                {% for error in form.roles.vars.errors %}
                                    {{ error.message }}
                                {% endfor %}
                            </div>
                        {% endif %}
                    </div>

                    <div class="form-group">
                        <div class="checkbox-container">
                            {{ form_widget(form.isActive, { 'attr': {'class': 'form-check-input'} }) }}
                            {{ form_label(form.isActive, null, { 'label_attr': {'class': 'form-check-label'} }) }}
                        </div>
                        {% if form.isActive.vars.errors|length > 0 %}
                            <div class="form-error">
                                {% for error in form.isActive.vars.errors %}
                                    {{ error.message }}
                                {% endfor %}
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>

            <div class="user-form-actions">
                <a href="{{ path('admin_user_index') }}" class="btn btn-secondary">Cancel</a>
                <button type="submit" class="btn btn-primary">Create User</button>
            </div>
        {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}
