{# Auto-refresh admin tables/stats without full page reload. #}
<script>
(function () {
  var POLL_MS = 2000;

  function isLoginPage(html) {
    return (
      html.indexOf('login') !== -1 &&
      (html.indexOf('Sign In') !== -1 || html.indexOf('authenticate') !== -1 || html.indexOf('<form') !== -1)
    );
  }

  function setLiveStatus(message, isError) {
    var el = document.getElementById('admin-live-status');
    if (!el) {
      return;
    }
    el.textContent = message;
    el.style.color = isError ? '#b42318' : '#2d6a4f';
  }

  function initAdminLivePoll() {
    var roots = document.querySelectorAll('[data-admin-live-url]');
    if (!roots.length) {
      return;
    }

    setLiveStatus('Live — updating every ' + POLL_MS / 1000 + 's', false);

    roots.forEach(function (root) {
      var url = root.getAttribute('data-admin-live-url');
      var targetSelector = root.getAttribute('data-admin-live-target');
      if (!url || !targetSelector) {
        return;
      }

      var lastHtml = '';
      var inFlight = false;
      var failCount = 0;

      function refresh() {
        if (document.hidden || inFlight) {
          return;
        }
        inFlight = true;

        fetch(url, {
          credentials: 'same-origin',
          headers: {
            'X-Requested-With': 'XMLHttpRequest',
            Accept: 'text/html',
          },
          cache: 'no-store',
        })
          .then(function (res) {
            if (!res.ok) {
              throw new Error('HTTP ' + res.status);
            }
            return res.text();
          })
          .then(function (html) {
            if (!html || isLoginPage(html)) {
              throw new Error('Session expired');
            }
            if (html === lastHtml) {
              failCount = 0;
              return;
            }
            var target = document.querySelector(targetSelector);
            if (!target) {
              throw new Error('Target not found');
            }
            target.innerHTML = html;
            lastHtml = html;
            failCount = 0;
            setLiveStatus('Live — updated ' + new Date().toLocaleTimeString(), false);
            target.classList.add('admin-live-updated');
            window.setTimeout(function () {
              target.classList.remove('admin-live-updated');
            }, 600);
          })
          .catch(function (err) {
            failCount += 1;
            if (failCount >= 2) {
              setLiveStatus(
                'Live sync paused — refresh page or sign in again (' + (err && err.message ? err.message : 'error') + ')',
                true,
              );
            }
          })
          .finally(function () {
            inFlight = false;
          });
      }

      refresh();
      window.setInterval(refresh, POLL_MS);
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAdminLivePoll);
  } else {
    initAdminLivePoll();
  }
})();
</script>
<style>
  #admin-live-status {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    font-weight: 600;
    margin-left: 12px;
    color: #2d6a4f;
  }
  #admin-live-status::before {
    content: '';
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #40c057;
    animation: admin-live-pulse 1.5s ease infinite;
  }
  .admin-live-updated {
    animation: admin-live-flash 0.6s ease;
  }
  @keyframes admin-live-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.35; }
  }
  @keyframes admin-live-flash {
    0% { background-color: rgba(255, 140, 0, 0.18); }
    100% { background-color: transparent; }
  }
</style>
