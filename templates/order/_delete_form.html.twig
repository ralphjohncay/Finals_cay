<form method="post" action="{{ path('app_order_delete', {'id': order.id}) }}" onsubmit="return confirm('Are you sure you want to delete this order? This action cannot be undone.');" style="display: inline;">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ order.id) }}">
    <button type="submit" class="order-btn order-btn-danger">
        <i class="bi bi-trash"></i> Delete Order
    </button>
</form>
