{% extends 'base.html.twig' %}

{% block title %}My Profile{% endblock %}

{% block page_title %}My Profile{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .profile-container {
            max-width: 900px;
            margin: 2rem auto;
        }

        .profile-header {
            background: linear-gradient(138deg, #e6d2b8 0%, #b88968 32%, #7d4a3a 68%, #3d221c 100%);
            padding: 2.5rem;
            border-radius: 16px 16px 0 0;
            color: white;
            display: flex;
            align-items: center;
            gap: 1.5rem;
        }

        .profile-avatar {
            width: 100px;
            height: 100px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.2);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2.5rem;
            font-weight: bold;
            border: 4px solid rgba(255, 255, 255, 0.3);
            flex-shrink: 0;
        }

        .profile-header-info h2 {
            margin: 0 0 0.5rem 0;
            font-size: 1.75rem;
            font-weight: 700;
        }

        .profile-header-info p {
            margin: 0;
            opacity: 0.9;
            font-size: 1rem;
        }

        .profile-card {
            background: #ffffff;
            border-radius: 0 0 16px 16px;
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
            overflow: hidden;
        }

        .profile-card-content {
            padding: 2.5rem;
        }

        .profile-section {
            margin-bottom: 2.5rem;
        }

        .profile-section:last-child {
            margin-bottom: 0;
        }

        .profile-section-title {
            font-size: 1.25rem;
            font-weight: 700;
            color: #3f2a24;
            margin: 0 0 1.5rem 0;
            padding-bottom: 0.75rem;
            border-bottom: 2px solid #d4a574;
        }

        .profile-form-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1.5rem;
        }

        @media (max-width: 768px) {
            .profile-form-grid {
                grid-template-columns: 1fr;
            }
            .profile-header {
                flex-direction: column;
                text-align: center;
            }
        }

        .profile-form-group {
            margin-bottom: 1.5rem;
        }

        .profile-form-group label {
            display: block;
            font-weight: 600;
            margin-bottom: 0.5rem;
            color: #2b2b2b;
            font-size: 0.95rem;
        }

        .profile-form-group input {
            width: 100%;
            padding: 0.75rem 1rem;
            border: 1px solid #ddd;
            border-radius: 10px;
            font-size: 1rem;
            box-sizing: border-box;
            transition: all 0.3s ease;
            background-color: #fff;
        }

        .profile-form-group input:focus {
            outline: none;
            border-color: #8f5644;
            box-shadow: 0 0 0 3px rgba(105, 62, 48, 0.15);
        }

        .profile-form-actions {
            display: flex;
            gap: 1rem;
            margin-top: 2rem;
            padding-top: 1.5rem;
            border-top: 1px solid #eee;
        }

        .profile-btn {
            padding: 0.75rem 1.5rem;
            border-radius: 10px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            border: none;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
        }

        .profile-btn-primary {
            background-color: #8f5644;
            color: white;
        }

        .profile-btn-primary:hover {
            background-color: #3f2a24;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(105, 62, 48, 0.3);
        }

        .profile-btn-secondary {
            background-color: #6c757d;
            color: white;
        }

        .profile-btn-secondary:hover {
            background-color: #5a6268;
            transform: translateY(-2px);
        }

        .profile-details-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 1.5rem;
        }

        .profile-detail-card {
            background: #f8f9fa;
            padding: 1.5rem;
            border-radius: 12px;
            border: 1px solid #e9ecef;
        }

        .profile-detail-label {
            font-size: 0.875rem;
            color: #6c757d;
            margin-bottom: 0.5rem;
            font-weight: 500;
        }

        .profile-detail-value {
            font-size: 1.1rem;
            color: #2b2b2b;
            font-weight: 600;
        }

        .profile-badge {
            display: inline-block;
            padding: 0.5rem 1rem;
            border-radius: 20px;
            font-size: 0.875rem;
            font-weight: 600;
        }

        .profile-badge-admin {
            background: #667eea;
            color: white;
        }

        .profile-badge-staff {
            background: #764ba2;
            color: white;
        }

        .profile-badge-user {
            background: #6c757d;
            color: white;
        }

        .profile-badge-active {
            background: #d4edda;
            color: #155724;
        }

        .profile-badge-inactive {
            background: #f8d7da;
            color: #721c24;
        }

        .profile-form-error {
            color: #dc3545;
            font-size: 0.875rem;
            margin-top: 0.5rem;
        }

        .profile-form-error ul {
            margin: 0;
            padding-left: 1.25rem;
        }
    </style>
{% endblock %}

{% block content %}
<div class="profile-container">
    <div class="profile-card">
        <div class="profile-header">
            <div class="profile-avatar">
                {{ app.user.name|first|upper }}
            </div>
            <div class="profile-header-info">
                <h2>{{ app.user.name }}</h2>
                <p>
                    {% if 'ROLE_ADMIN' in app.user.roles %}
                        <i class="bi bi-shield-check"></i> Administrator
                    {% elseif 'ROLE_STAFF' in app.user.roles %}
                        <i class="bi bi-person-badge"></i> Staff Member
                    {% else %}
                        <i class="bi bi-person"></i> User
                    {% endif %}
                </p>
            </div>
        </div>

        <div class="profile-card-content">
            {% if form.vars.submitted and not form.vars.valid %}
                <div style="background: #f8d7da; color: #721c24; padding: 1rem; border-radius: 8px; margin-bottom: 1.5rem; border: 1px solid #f5c6cb;">
                    <strong>Please fix the following errors:</strong>
                    {{ form_errors(form) }}
                </div>
            {% endif %}

            {{ form_start(form, { 'attr': { 'novalidate': 'novalidate' } }) }}
                <div class="profile-section">
                    <h3 class="profile-section-title">
                        <i class="bi bi-person-circle"></i> Personal Information
                    </h3>
                    <div class="profile-form-grid">
                        <div class="profile-form-group">
                            {{ form_label(form.name) }}
                            {{ form_widget(form.name, { 'attr': {'class': 'form-control'} }) }}
                            {% if form.name.vars.errors|length > 0 %}
                                <div class="profile-form-error">
                                    {% for error in form.name.vars.errors %}
                                        {{ error.message }}
                                    {% endfor %}
                                </div>
                            {% endif %}
                        </div>
                        <div class="profile-form-group">
                            {{ form_label(form.email) }}
                            {{ form_widget(form.email, { 'attr': {'class': 'form-control'} }) }}
                            {% if form.email.vars.errors|length > 0 %}
                                <div class="profile-form-error">
                                    {% for error in form.email.vars.errors %}
                                        {{ error.message }}
                                    {% endfor %}
                                </div>
                            {% endif %}
                        </div>
                    </div>
                    <div class="profile-form-actions">
                        <button type="submit" class="profile-btn profile-btn-primary">
                            <i class="bi bi-check-circle"></i> Update Profile
                        </button>
                        <a href="{{ path('app_change_password') }}" class="profile-btn profile-btn-secondary">
                            <i class="bi bi-key"></i> Change Password
                        </a>
                    </div>
                </div>
            {{ form_end(form) }}

            <div class="profile-section">
                <h3 class="profile-section-title">
                    <i class="bi bi-info-circle"></i> Account Details
                </h3>
                <div class="profile-details-grid">
                    <div class="profile-detail-card">
                        <div class="profile-detail-label">Role</div>
                        <div class="profile-detail-value">
                            <span class="profile-badge 
                                {% if 'ROLE_ADMIN' in app.user.roles %}profile-badge-admin
                                {% elseif 'ROLE_STAFF' in app.user.roles %}profile-badge-staff
                                {% else %}profile-badge-user{% endif %}">
                                {% if 'ROLE_ADMIN' in app.user.roles %}
                                    <i class="bi bi-shield-check"></i> Admin
                                {% elseif 'ROLE_STAFF' in app.user.roles %}
                                    <i class="bi bi-person-badge"></i> Staff
                                {% else %}
                                    <i class="bi bi-person"></i> User
                                {% endif %}
                            </span>
                        </div>
                    </div>
                    <div class="profile-detail-card">
                        <div class="profile-detail-label">Account Status</div>
                        <div class="profile-detail-value">
                            <span class="profile-badge {% if app.user.isActive %}profile-badge-active{% else %}profile-badge-inactive{% endif %}">
                                {% if app.user.isActive %}
                                    <i class="bi bi-check-circle"></i> Active
                                {% else %}
                                    <i class="bi bi-x-circle"></i> Disabled
                                {% endif %}
                            </span>
                        </div>
                    </div>
                    <div class="profile-detail-card">
                        <div class="profile-detail-label">Account Created</div>
                        <div class="profile-detail-value">
                            <i class="bi bi-calendar"></i> {{ app.user.createdAt|date('F d, Y') }}
                        </div>
                    </div>
                    <div class="profile-detail-card">
                        <div class="profile-detail-label">Time Created</div>
                        <div class="profile-detail-value">
                            <i class="bi bi-clock-history"></i> {{ app.user.createdAt|date('g:i A') }}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

