# Copy to .env and set your PC's LAN IP when testing on a physical phone.
# Symfony must be running: symfony serve:start
EXPO_PUBLIC_API_URL=http://127.0.0.1:8000

# Android emulator uses 10.0.2.2 automatically (see src/config.ts).
# Example for physical device on Wi‑Fi:
# EXPO_PUBLIC_API_URL=http://192.168.1.100:8000
