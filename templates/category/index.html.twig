{% extends 'base.html.twig' %}

{% block title %}Categories{% endblock %}

{% block page_title %}Category{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('productindex') }}
    <style>
        .category-index-section {
            padding: 2rem 0;
        }

        .category-index-section h2 {
            margin-bottom: 2rem;
            font-size: 1.75rem;
            font-weight: 700;
            color: #3f2a24;
        }

        .category-index-actions {
            display: flex;
            justify-content: flex-end;
            margin-bottom: 2rem;
        }

        .category-index-table-container {
            margin-top: 1.5rem;
        }

        #categoriesTable {
            margin-top: 1rem;
        }

        #categoriesTable th {
            background-color: #8f5644;
            color: #fff;
            padding: 1.25rem 1.5rem;
        }

        #categoriesTable td {
            padding: 1.25rem 1.5rem;
        }

        #categoriesTable .btn-sm {
            margin: 0 0.5rem;
            padding: 0.6rem 1.25rem;
        }

        #categoriesTable td {
            padding: 1.25rem 1.5rem;
        }
    </style>
{% endblock %}

{% block content %}
<section class="section category-index-section">
    <h2>Categories</h2>

    <div class="category-index-actions">
        <a href="{{ path('app_category_new') }}" class="btn btn-primary">+ Add New Category</a>
    </div>

    <div class="category-index-table-container">
        <table id="categoriesTable" class="table table-striped table-hover table-bordered display nowrap" style="width:100%">
        <thead>
            <tr>
                <th>Category Name</th>
                <th>Description</th>
                <th>Created</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for category in categories %}
                <tr>
                    <td>{{ category.name }}</td>
                    <td>{{ category.description ?: '—' }}</td>
                    <td>{{ category.createdAt ? category.createdAt|date('Y-m-d') : '—' }}</td>
                    <td>
                        {% if is_granted('ROLE_ADMIN') or (app.user and category.createdBy and category.createdBy.id == app.user.id) %}
                            <a href="{{ path('app_category_edit', {'id': category.id}) }}" class="btn btn-edit btn-sm">Edit</a>
                            <form action="{{ path('app_category_delete', {'id': category.id}) }}" method="POST" class="inline-form d-inline" onsubmit="return confirm('Are you sure you want to delete this category?');" style="display: inline-block; margin-left: 0.5rem;">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ category.id) }}">
                                <button type="submit" class="btn btn-delete btn-sm">Delete</button>
                            </form>
                        {% else %}
                            <span style="color: #999; font-size: 12px;">Read-only</span>
                        {% endif %}
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="4" style="text-align: center; padding: 20px;">No categories found</td>
                </tr>
            {% endfor %}
        </tbody>
        </table>
    </div>
</section>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('productindex') }}
{% endblock %}

