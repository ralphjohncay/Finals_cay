{% extends 'base.html.twig' %}

{% block title %}Products{% endblock %}

{% block page_title %}Products{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .product-index-container {
            max-width: 1600px;
            margin: 0 auto;
        }

        .product-index-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 2rem;
            flex-wrap: wrap;
            gap: 1rem;
        }

        .product-index-header h2 {
            margin: 0;
            font-size: 1.75rem;
            font-weight: 700;
            color: #3f2a24;
        }

        .product-index-actions {
            display: flex;
            gap: 1rem;
            align-items: center;
            flex-wrap: wrap;
        }

        .product-filter-group {
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .product-filter-group label {
            font-weight: 600;
            color: #2b2b2b;
            font-size: 0.95rem;
            white-space: nowrap;
        }

        .product-filter-group select {
            padding: 0.75rem 1rem;
            border: 2px solid #e0e0e0;
            border-radius: 8px;
            font-size: 0.95rem;
            background: white;
            min-width: 200px;
            transition: all 0.3s ease;
        }

        .product-filter-group select:focus {
            outline: none;
            border-color: #8f5644;
            box-shadow: 0 0 0 3px rgba(105, 62, 48, 0.1);
        }

        .product-add-btn {
            padding: 0.75rem 1.5rem;
            background: linear-gradient(138deg, #e6d2b8 0%, #b88968 32%, #7d4a3a 68%, #3d221c 100%);
            color: white;
            text-decoration: none;
            border-radius: 10px;
            font-weight: 600;
            font-size: 1rem;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            transition: all 0.3s ease;
            box-shadow: 0 2px 8px rgba(105, 62, 48, 0.2);
        }

        .product-add-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(105, 62, 48, 0.3);
        }

        .product-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 1.5rem;
            margin-top: 2rem;
        }

        .product-card {
            background: #ffffff;
            border-radius: 12px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
            overflow: hidden;
            transition: all 0.3s ease;
            display: flex;
            flex-direction: column;
        }

        .product-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
        }

        .product-card-image {
            width: 100%;
            height: 200px;
            overflow: hidden;
            position: relative;
        }

        .product-card-image-placeholder {
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, #f5f5f5 0%, #e0e0e0 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #999;
            font-size: 3rem;
        }

        .product-card-image-placeholder::before {
            content: '📦';
            font-size: 4rem;
            opacity: 0.3;
        }

        .product-card-image-actual {
            width: 100%;
            height: 100%;
            object-fit: cover;
            background: #f8f9fa;
        }

        .product-card-body {
            padding: 1.25rem;
            flex-grow: 1;
            display: flex;
            flex-direction: column;
        }

        .product-card-name {
            font-size: 1.25rem;
            font-weight: 600;
            color: #2b2b2b;
            margin-bottom: 0.75rem;
        }

        .product-card-details {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
            margin-bottom: 1rem;
            flex-grow: 1;
        }

        .product-card-detail {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-size: 0.9rem;
            color: #6c757d;
        }

        .product-card-detail strong {
            color: #2b2b2b;
            font-weight: 600;
            min-width: 70px;
        }

        .product-card-price {
            font-size: 1.5rem;
            font-weight: 700;
            color: #8f5644;
            margin: 0.75rem 0;
        }

        .product-card-actions {
            display: flex;
            gap: 0.5rem;
            margin-top: auto;
            padding-top: 1rem;
            border-top: 1px solid #eee;
        }

        .product-action-btn {
            flex: 1;
            padding: 0.6rem;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
            text-decoration: none;
        }

        .product-action-btn-view {
            background: #2b2b2b;
            color: white;
        }

        .product-action-btn-view:hover {
            background: #1a1a1a;
            transform: translateY(-2px);
        }

        .product-action-btn-edit {
            background: #667eea;
            color: white;
        }

        .product-action-btn-edit:hover {
            background: #5568d3;
            transform: translateY(-2px);
        }

        .product-action-btn-delete {
            background: #dc3545;
            color: white;
        }

        .product-action-btn-delete:hover {
            background: #c82333;
            transform: translateY(-2px);
        }

        .product-empty {
            grid-column: 1 / -1;
            text-align: center;
            padding: 3rem;
            color: #6c757d;
        }

        .product-empty i {
            font-size: 3rem;
            margin-bottom: 1rem;
            color: #dee2e6;
        }

        @media (max-width: 768px) {
            .product-index-header {
                flex-direction: column;
                align-items: stretch;
            }

            .product-index-actions {
                flex-direction: column;
            }

            .product-filter-group {
                width: 100%;
            }

            .product-filter-group select {
                width: 100%;
            }

            .product-add-btn {
                width: 100%;
                justify-content: center;
            }

            .product-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
{% endblock %}

{% block content %}
<div class="product-index-container">
    <div class="product-index-header">
    <h2>Products</h2>
    <div class="product-index-actions">
            <div class="product-filter-group">
                <label for="category-filter">Filter by Category:</label>
                <select id="category-filter" onchange="filterByCategory(this.value)">
                    <option value="">All Categories</option>
                    {% for category in categories %}
                        <option value="{{ category }}" {% if selectedCategory == category %}selected{% endif %}>{{ category }}</option>
                    {% endfor %}
                </select>
            </div>
            <a href="{{ path('app_product_new') }}" class="product-add-btn">
                <i class="bi bi-plus-circle"></i>
                Add New Product
            </a>
        </div>
    </div>

    <div class="product-grid">
            {% for product in products %}
            <div class="product-card">
                <div class="product-card-image">
                    {% if product.image %}
                        <img src="{{ asset('uploads/products/' ~ product.image) }}" alt="{{ product.name }}" class="product-card-image-actual">
                    {% else %}
                        <div class="product-card-image-placeholder">
                            <!-- Placeholder icon -->
                        </div>
                    {% endif %}
                </div>
                <div class="product-card-body">
                    <div class="product-card-name">{{ product.name }}</div>
                    <div class="product-card-details">
                        <div class="product-card-detail">
                            <strong>Stock:</strong>
                            <span>{{ product.stock }}</span>
                        </div>
                        <div class="product-card-detail">
                            <strong>Category:</strong>
                            <span>{{ product.category ?: 'Uncategorized' }}</span>
                        </div>
                    </div>
                    <div class="product-card-price">₱{{ product.price }}</div>
                    <div class="product-card-actions">
                        <a href="{{ path('app_product_view', {'id': product.id}) }}" class="product-action-btn product-action-btn-view" title="View">
                            <i class="bi bi-eye"></i>
                        </a>
                        {% if is_granted('ROLE_ADMIN') or (app.user and product.createdBy and product.createdBy.id == app.user.id) %}
                            <a href="{{ path('app_product_edit', {'id': product.id}) }}" class="product-action-btn product-action-btn-edit" title="Edit">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form action="{{ path('app_product_delete', {'id': product.id}) }}" method="POST" style="display: inline; margin: 0;" onsubmit="return confirm('Are you sure you want to delete this product?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ product.id) }}">
                                <button type="submit" class="product-action-btn product-action-btn-delete" title="Delete">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        {% endif %}
                    </div>
                </div>
            </div>
        {% else %}
            <div class="product-empty">
                <i class="bi bi-inbox"></i>
                <p>No products found</p>
            </div>
            {% endfor %}
    </div>
</div>

<script>
function filterByCategory(category) {
    const url = new URL(window.location.href);
    if (category) {
        url.searchParams.set('category', category);
    } else {
        url.searchParams.delete('category');
    }
    window.location.href = url.toString();
}
</script>
{% endblock %}
